<Window x:Class="DMShot.Editor.EditorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ed="clr-namespace:DMShot.Editor"
        Title="DM_Screenshot" Width="1100" Height="750" MinWidth="900" MinHeight="560"
        Background="{StaticResource DmBackground}" Icon="/Resources/AppIcon.ico"
        TextOptions.TextFormattingMode="Ideal" UseLayoutRounding="True">
  <Window.Resources>
    <!-- Vertical divider used between toolbar groups -->
    <Style x:Key="VDivider" TargetType="Rectangle">
      <Setter Property="Width" Value="1"/>
      <Setter Property="Height" Value="22"/>
      <Setter Property="Fill" Value="{StaticResource DmBorder}"/>
      <Setter Property="Margin" Value="7,0"/>
      <Setter Property="VerticalAlignment" Value="Center"/>
    </Style>
    <!-- Palette swatch button -->
    <Style x:Key="Swatch" TargetType="Button">
      <Setter Property="Width" Value="26"/>
      <Setter Property="Height" Value="26"/>
      <Setter Property="Cursor" Value="Hand"/>
      <Setter Property="Margin" Value="3"/>
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="Button">
            <Grid>
              <Ellipse Fill="{TemplateBinding Background}"/>
              <Ellipse Stroke="#55FFFFFF" StrokeThickness="1"/>
            </Grid>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>
  </Window.Resources>

  <DockPanel>
    <!-- ===================== Toolbar ===================== -->
    <Border DockPanel.Dock="Top" Background="{StaticResource DmBackground}"
            BorderBrush="{StaticResource DmBorder}" BorderThickness="0,0,0,1">
      <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled">
        <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="12,8">

          <!-- Copy / Save -->
          <Button Style="{StaticResource IconButton}" Click="CopyClick" ToolTip="Copy">
            <StackPanel Orientation="Horizontal">
              <Viewbox Width="16" Height="16">
                <Path Data="M9,8.5 L18.5,8.5 L18.5,20 L9,20 Z M5.5,4 L15,4 L15,5.5 M5.5,4 L5.5,15.5 L7,15.5"
                      Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                      StrokeThickness="2" StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round"/>
              </Viewbox>
              <TextBlock Text="Copy" Margin="6,0,0,0" VerticalAlignment="Center"/>
            </StackPanel>
          </Button>
          <Button Style="{StaticResource IconButton}" Click="SaveClick" ToolTip="Save">
            <StackPanel Orientation="Horizontal">
              <Viewbox Width="16" Height="16">
                <Path Data="M12,3.5 L12,14.5 M7.5,10 L12,14.5 L16.5,10 M5,19.5 L19,19.5"
                      Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                      StrokeThickness="2" StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round"/>
              </Viewbox>
              <TextBlock Text="Save" Margin="6,0,0,0" VerticalAlignment="Center"/>
            </StackPanel>
          </Button>

          <Rectangle Style="{StaticResource VDivider}"/>

          <!-- Tools (grouped in a lighter pill) -->
          <Border Background="{StaticResource DmSurfaceLight}" CornerRadius="9" Padding="3">
            <StackPanel Orientation="Horizontal">
              <RadioButton x:Name="ToolSelect" Style="{StaticResource ToolRadio}" GroupName="tools" Tag="Select" Checked="ToolChecked" IsChecked="True" ToolTip="Select / Move">
                <Viewbox Width="18" Height="18"><Path Data="M6,3 L6,19.5 L10.2,15.3 L13.2,21.5 L15.6,20.4 L12.6,14.4 L18.5,14.4 Z" Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=RadioButton}}"/></Viewbox>
              </RadioButton>
              <RadioButton Style="{StaticResource ToolRadio}" GroupName="tools" Tag="Arrow" Checked="ToolChecked" ToolTip="Arrow">
                <Viewbox Width="18" Height="18"><Path Data="M5.5,18.5 L18.5,5.5 M18.5,5.5 L11.5,5.5 M18.5,5.5 L18.5,12.5" Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=RadioButton}}" StrokeThickness="2" StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round"/></Viewbox>
              </RadioButton>
              <RadioButton Style="{StaticResource ToolRadio}" GroupName="tools" Tag="Rectangle" Checked="ToolChecked" ToolTip="Rectangle">
                <Viewbox Width="18" Height="18"><Path Data="M4.5,6.5 L19.5,6.5 L19.5,17.5 L4.5,17.5 Z" Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=RadioButton}}" StrokeThickness="2" StrokeLineJoin="Round"/></Viewbox>
              </RadioButton>
              <RadioButton Style="{StaticResource ToolRadio}" GroupName="tools" Tag="Ellipse" Checked="ToolChecked" ToolTip="Ellipse">
                <Viewbox Width="18" Height="18"><Path Data="M12,6 C16.7,6 19.5,8.7 19.5,12 C19.5,15.3 16.7,18 12,18 C7.3,18 4.5,15.3 4.5,12 C4.5,8.7 7.3,6 12,6 Z" Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=RadioButton}}" StrokeThickness="2"/></Viewbox>
              </RadioButton>
              <RadioButton Style="{StaticResource ToolRadio}" GroupName="tools" Tag="Underline" Checked="ToolChecked" ToolTip="Underline">
                <Viewbox Width="18" Height="18"><Path Data="M6.5,4 L6.5,10.5 C6.5,13.5 8.9,15.5 12,15.5 C15.1,15.5 17.5,13.5 17.5,10.5 L17.5,4 M5.5,19.5 L18.5,19.5" Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=RadioButton}}" StrokeThickness="2" StrokeStartLineCap="Round" StrokeEndLineCap="Round"/></Viewbox>
              </RadioButton>
              <RadioButton Style="{StaticResource ToolRadio}" GroupName="tools" Tag="Highlighter" Checked="ToolChecked" ToolTip="Highlighter">
                <Viewbox Width="18" Height="18"><Path Data="M3.5,20.6 L3.5,16.9 L13.4,7 L17.3,10.9 L7.4,20.8 Z M13.7,6.7 L16.5,3.9 L20.4,7.8 L17.6,10.6 Z" Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=RadioButton}}"/></Viewbox>
              </RadioButton>
              <RadioButton Style="{StaticResource ToolRadio}" GroupName="tools" Tag="Step" Checked="ToolChecked" ToolTip="Numbered step">
                <Viewbox Width="18" Height="18"><Path Data="M9,4.5 L7.5,19.5 M16.5,4.5 L15,19.5 M5,9.5 L18.5,9.5 M4.5,14.5 L18,14.5" Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=RadioButton}}" StrokeThickness="2" StrokeStartLineCap="Round" StrokeEndLineCap="Round"/></Viewbox>
              </RadioButton>
              <RadioButton Style="{StaticResource ToolRadio}" GroupName="tools" Tag="Text" Checked="ToolChecked" ToolTip="Text">
                <Viewbox Width="18" Height="18"><Path Data="M5,5 L19,5 M12,5 L12,19.5 M9,19.5 L15,19.5" Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=RadioButton}}" StrokeThickness="2" StrokeStartLineCap="Round" StrokeEndLineCap="Round"/></Viewbox>
              </RadioButton>
              <RadioButton Style="{StaticResource ToolRadio}" GroupName="tools" Tag="Blur" Checked="ToolChecked" ToolTip="Blur / Pixelate">
                <Viewbox Width="18" Height="18"><Path Data="M5,5 L8,5 L8,8 L5,8 Z M10.5,5 L13.5,5 L13.5,8 L10.5,8 Z M16,5 L19,5 L19,8 L16,8 Z M5,10.5 L8,10.5 L8,13.5 L5,13.5 Z M10.5,10.5 L13.5,10.5 L13.5,13.5 L10.5,13.5 Z M16,10.5 L19,10.5 L19,13.5 L16,13.5 Z M5,16 L8,16 L8,19 L5,19 Z M10.5,16 L13.5,16 L13.5,19 L10.5,19 Z M16,16 L19,16 L19,19 L16,19 Z" Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=RadioButton}}"/></Viewbox>
              </RadioButton>
              <RadioButton Style="{StaticResource ToolRadio}" GroupName="tools" Tag="Crop" Checked="ToolChecked" ToolTip="Crop">
                <Viewbox Width="18" Height="18"><Path Data="M7,2.5 L7,17 L21.5,17 M2.5,7 L17,7 L17,21.5" Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=RadioButton}}" StrokeThickness="2" StrokeStartLineCap="Round" StrokeEndLineCap="Round"/></Viewbox>
              </RadioButton>
            </StackPanel>
          </Border>

          <Rectangle Style="{StaticResource VDivider}"/>

          <!-- Color swatch + popover -->
          <Button x:Name="ColorSwatchButton" Click="OpenColorPopup" Cursor="Hand" ToolTip="Color">
            <Button.Template>
              <ControlTemplate TargetType="Button">
                <Border Background="Transparent" Padding="2">
                  <ContentPresenter/>
                </Border>
              </ControlTemplate>
            </Button.Template>
            <Grid Width="24" Height="24">
              <Ellipse x:Name="SwatchFill" Fill="{StaticResource DmAccent}"/>
              <Ellipse Stroke="#88FFFFFF" StrokeThickness="1.5"/>
            </Grid>
          </Button>
          <Popup x:Name="ColorPopup" PlacementTarget="{Binding ElementName=ColorSwatchButton}" Placement="Bottom" StaysOpen="False" AllowsTransparency="True">
            <Border Background="{StaticResource DmSurface}" BorderBrush="{StaticResource DmBorder}" BorderThickness="1" CornerRadius="10" Padding="12" Margin="0,6,0,0">
              <StackPanel Width="176">
                <UniformGrid Columns="4">
                  <Button Style="{StaticResource Swatch}" Background="#C97B4A" Tag="#C97B4A" Click="PaletteClick"/>
                  <Button Style="{StaticResource Swatch}" Background="#EF4444" Tag="#EF4444" Click="PaletteClick"/>
                  <Button Style="{StaticResource Swatch}" Background="#F59E0B" Tag="#F59E0B" Click="PaletteClick"/>
                  <Button Style="{StaticResource Swatch}" Background="#10B981" Tag="#10B981" Click="PaletteClick"/>
                  <Button Style="{StaticResource Swatch}" Background="#3B82F6" Tag="#3B82F6" Click="PaletteClick"/>
                  <Button Style="{StaticResource Swatch}" Background="#8B5CF6" Tag="#8B5CF6" Click="PaletteClick"/>
                  <Button Style="{StaticResource Swatch}" Background="#000000" Tag="#000000" Click="PaletteClick"/>
                  <Button Style="{StaticResource Swatch}" Background="#FFFFFF" Tag="#FFFFFF" Click="PaletteClick"/>
                </UniformGrid>
                <Rectangle Height="1" Fill="{StaticResource DmBorder}" Margin="0,10"/>
                <StackPanel Orientation="Horizontal">
                  <TextBlock Text="Hex" Foreground="{StaticResource DmTextDim}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                  <TextBox x:Name="HexBox" Style="{StaticResource DmTextBox}" Width="110" Text="#C97B4A" KeyDown="HexChanged"/>
                </StackPanel>
              </StackPanel>
            </Border>
          </Popup>

          <Rectangle Style="{StaticResource VDivider}"/>

          <!-- Contextual slider: Size (default) or Blur -->
          <StackPanel x:Name="SizePanel" Orientation="Horizontal" VerticalAlignment="Center">
            <TextBlock Text="Size" Foreground="{StaticResource DmTextDim}" VerticalAlignment="Center" Margin="0,0,6,0"/>
            <Slider x:Name="StrokeSlider" Width="96" Minimum="1" Maximum="20" Value="3" VerticalAlignment="Center"/>
            <TextBlock x:Name="StrokeVal" Text="3px" Width="34" Margin="6,0,0,0" VerticalAlignment="Center" FontFamily="Consolas"/>
          </StackPanel>
          <StackPanel x:Name="BlurPanel" Orientation="Horizontal" VerticalAlignment="Center" Visibility="Collapsed">
            <TextBlock Text="Blur" Foreground="{StaticResource DmTextDim}" VerticalAlignment="Center" Margin="0,0,6,0"/>
            <Slider x:Name="BlurSlider" Width="96" Minimum="4" Maximum="40" Value="12" VerticalAlignment="Center"/>
            <TextBlock x:Name="BlurVal" Text="12" Width="34" Margin="6,0,0,0" VerticalAlignment="Center" FontFamily="Consolas"/>
          </StackPanel>

          <Rectangle Style="{StaticResource VDivider}"/>

          <!-- Undo / Redo -->
          <Button Style="{StaticResource IconButton}" Click="UndoClick" ToolTip="Undo">
            <Viewbox Width="16" Height="16"><Path Data="M8.5,7.5 L4.5,11.5 L8.5,15.5 M4.5,11.5 L14,11.5 C17,11.5 19,13.7 19,16.5 C19,19.3 17,21.5 14,21.5 L10.5,21.5" Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" StrokeThickness="2" StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round"/></Viewbox>
          </Button>
          <Button Style="{StaticResource IconButton}" Click="RedoClick" ToolTip="Redo">
            <Viewbox Width="16" Height="16"><Path Data="M15.5,7.5 L19.5,11.5 L15.5,15.5 M19.5,11.5 L10,11.5 C7,11.5 5,13.7 5,16.5 C5,19.3 7,21.5 10,21.5 L13.5,21.5" Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" StrokeThickness="2" StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round"/></Viewbox>
          </Button>

          <Rectangle Style="{StaticResource VDivider}"/>

          <TextBlock x:Name="DimText" Foreground="{StaticResource DmTextDim}" VerticalAlignment="Center" FontSize="12"/>
        </StackPanel>
      </ScrollViewer>
    </Border>

    <!-- ===================== Sidebar ===================== -->
    <Border DockPanel.Dock="Left" Width="168" Background="{StaticResource DmBackground}"
            BorderBrush="{StaticResource DmBorder}" BorderThickness="0,0,1,0">
      <DockPanel Margin="10">
        <Button DockPanel.Dock="Top" Style="{StaticResource SidebarButton}" Click="FullScreenClick" Margin="0,0,0,8">
          <StackPanel Orientation="Horizontal">
            <Viewbox Width="16" Height="16"><Path Data="M4,8.5 L4,4 L8.5,4 M15.5,4 L20,4 L20,8.5 M20,15.5 L20,20 L15.5,20 M8.5,20 L4,20 L4,15.5" Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" StrokeThickness="2" StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round"/></Viewbox>
            <TextBlock Text="Full Screen" Margin="10,0,0,0" VerticalAlignment="Center"/>
          </StackPanel>
        </Button>
        <Button DockPanel.Dock="Top" Style="{StaticResource SidebarButton}" Click="AreaClick" Margin="0,0,0,12">
          <StackPanel Orientation="Horizontal">
            <Viewbox Width="16" Height="16"><Path Data="M3.5,7 L3.5,3.5 L7,3.5 M17,3.5 L20.5,3.5 L20.5,7 M20.5,17 L20.5,20.5 L17,20.5 M7,20.5 L3.5,20.5 L3.5,17 M11,3.5 L13,3.5 M11,20.5 L13,20.5 M3.5,11 L3.5,13 M20.5,11 L20.5,13" Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" StrokeThickness="2" StrokeStartLineCap="Round" StrokeEndLineCap="Round"/></Viewbox>
            <TextBlock Text="Selection" Margin="10,0,0,0" VerticalAlignment="Center"/>
          </StackPanel>
        </Button>

        <TextBlock DockPanel.Dock="Top" Text="HISTORY" Foreground="{StaticResource DmTextDim}"
                   FontSize="11" FontWeight="SemiBold" Margin="2,0,0,6"/>

        <Button DockPanel.Dock="Bottom" Style="{StaticResource SidebarButton}" Click="SettingsClick" Margin="0,12,0,0">
          <StackPanel Orientation="Horizontal">
            <Viewbox Width="16" Height="16"><Path Data="M12,9 C13.66,9 15,10.34 15,12 C15,13.66 13.66,15 12,15 C10.34,15 9,13.66 9,12 C9,10.34 10.34,9 12,9 Z M12,3.5 L12,6 M12,18 L12,20.5 M3.5,12 L6,12 M18,12 L20.5,12 M5.8,5.8 L7.6,7.6 M16.4,16.4 L18.2,18.2 M18.2,5.8 L16.4,7.6 M7.6,16.4 L5.8,18.2" Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" StrokeThickness="2" StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round"/></Viewbox>
            <TextBlock Text="Settings" Margin="10,0,0,0" VerticalAlignment="Center"/>
          </StackPanel>
        </Button>

        <ListBox x:Name="HistoryList" Background="Transparent" BorderThickness="0"
                 SelectionChanged="HistorySelected"
                 ScrollViewer.HorizontalScrollBarVisibility="Disabled">
          <ListBox.ItemContainerStyle>
            <Style TargetType="ListBoxItem">
              <Setter Property="Padding" Value="0"/>
              <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
              <Setter Property="Template">
                <Setter.Value>
                  <ControlTemplate TargetType="ListBoxItem">
                    <Border x:Name="Bd" BorderThickness="2" BorderBrush="Transparent" CornerRadius="6" Margin="0,3">
                      <ContentPresenter/>
                    </Border>
                    <ControlTemplate.Triggers>
                      <Trigger Property="IsSelected" Value="True">
                        <Setter TargetName="Bd" Property="BorderBrush" Value="{StaticResource DmAccent}"/>
                      </Trigger>
                    </ControlTemplate.Triggers>
                  </ControlTemplate>
                </Setter.Value>
              </Setter>
            </Style>
          </ListBox.ItemContainerStyle>
          <ListBox.ItemTemplate>
            <DataTemplate>
              <Image Source="{Binding Thumb}" Stretch="Uniform" MaxHeight="120"/>
            </DataTemplate>
          </ListBox.ItemTemplate>
        </ListBox>
      </DockPanel>
    </Border>

    <!-- ===================== Canvas ===================== -->
    <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto" Background="#141418">
      <ed:CanvasControl x:Name="Canvas" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="24"/>
    </ScrollViewer>
  </DockPanel>
</Window>
