<Window x:Class="DMShot.Capture.OverlayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None" ResizeMode="NoResize" AllowsTransparency="False"
        ShowInTaskbar="False" Topmost="True" Background="Black" Cursor="Cross">
  <Grid>
    <Image x:Name="FrozenImage" Stretch="Fill"/>
    <Canvas x:Name="Overlay">
      <!-- 0x59 = 0.35 alpha, mac's dim value -->
      <Rectangle x:Name="DimTop" Fill="#59000000"/>
      <Rectangle x:Name="DimBottom" Fill="#59000000"/>
      <Rectangle x:Name="DimLeft" Fill="#59000000"/>
      <Rectangle x:Name="DimRight" Fill="#59000000"/>
      <Rectangle x:Name="SelRect" Stroke="#C97B4A" StrokeThickness="1.5"/>
      <Border x:Name="ReadoutBox" Background="#CC1F1F24" CornerRadius="3" Padding="6,2">
        <TextBlock x:Name="Readout" Foreground="White" FontSize="12"/>
      </Border>
      <Border x:Name="LoupeBox" Visibility="Collapsed"
              BorderBrush="#C97B4A" BorderThickness="1.5" CornerRadius="6"
              Background="#EB1E1E22">
        <Border.Effect>
          <DropShadowEffect BlurRadius="8" ShadowDepth="0" Opacity="0.5"/>
        </Border.Effect>
        <Grid Width="128" Height="128">
          <Image x:Name="LoupeImage" Width="128" Height="128" Stretch="Fill"
                 RenderOptions.BitmapScalingMode="NearestNeighbor"/>
          <Line X1="64" Y1="0" X2="64" Y2="128"
                Stroke="#99D9D9D9" StrokeThickness="1" StrokeDashArray="3 3"/>
          <Line X1="0" Y1="64" X2="128" Y2="64"
                Stroke="#99D9D9D9" StrokeThickness="1" StrokeDashArray="3 3"/>
        </Grid>
      </Border>
      <Border x:Name="LoupeCoordBox" Visibility="Collapsed"
              Background="#991F1F24" CornerRadius="3" Padding="6,2">
        <TextBlock x:Name="LoupeCoord" Foreground="#E6E6E6" FontSize="11"/>
      </Border>
    </Canvas>
  </Grid>
</Window>
