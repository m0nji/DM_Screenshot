<Window x:Class="DMShot.Video.GifViewerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="GIF Preview" Width="520" Height="420"
        MinWidth="280" MinHeight="200" MaxWidth="900" MaxHeight="700"
        Background="{StaticResource DmBackground}"
        TextOptions.TextFormattingMode="Ideal" UseLayoutRounding="True">

  <DockPanel>
    <!-- ===== Animated GIF preview ===== -->
    <Border DockPanel.Dock="Top" Background="#0D0D10" Margin="16,16,16,0" CornerRadius="6"
            BorderBrush="{StaticResource DmBorder}" BorderThickness="1">
      <Image x:Name="GifImage" Stretch="Uniform" MaxHeight="540"/>
    </Border>

    <!-- ===== Bottom panel: Copy + Save buttons ===== -->
    <Border DockPanel.Dock="Bottom" Margin="16,12,16,16"
            Background="{StaticResource DmSurface}" CornerRadius="10"
            BorderBrush="{StaticResource DmBorder}" BorderThickness="1" Padding="16,12">
      <Grid>
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*"/>
          <ColumnDefinition Width="Auto"/>
          <ColumnDefinition Width="8"/>
          <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>

        <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
          <TextBlock Foreground="{StaticResource DmTextDim}" FontSize="12" Text="GIF ready"/>
        </StackPanel>

        <Button x:Name="CopyButton" Grid.Column="1" Content="Copy"
                MinWidth="80" Height="32"/>
        <!-- spacer via ColumnDefinition Width="8" -->
        <Button x:Name="SaveButton" Grid.Column="3" Content="Save…"
                Style="{StaticResource AccentButton}" MinWidth="100" Height="32"/>
      </Grid>
    </Border>
  </DockPanel>
</Window>
