<Window x:Class="DMShot.Settings.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:s="clr-namespace:DMShot.Settings"
        xmlns:loc="clr-namespace:DMShot.Localization"
        Title="{loc:Tr settingsTitle}" Width="640" Height="420" Background="{StaticResource DmBackground}"
        Icon="/Resources/AppIcon.ico" TextOptions.TextFormattingMode="Ideal" UseLayoutRounding="True"
        WindowStartupLocation="CenterScreen">
  <Grid>
    <Grid.ColumnDefinitions>
      <ColumnDefinition Width="180"/>
      <ColumnDefinition Width="*"/>
    </Grid.ColumnDefinitions>

    <!-- Nav -->
    <Border Grid.Column="0" Background="{StaticResource DmSurfaceAlt}" BorderBrush="{StaticResource DmBorder}" BorderThickness="0,0,1,0">
      <ListBox x:Name="Nav" Background="Transparent" BorderThickness="0" Margin="10,14"
               SelectionChanged="NavChanged" ItemContainerStyle="{StaticResource NavItem}">
        <ListBoxItem IsSelected="True">
          <StackPanel Orientation="Horizontal">
            <Viewbox Width="18" Height="18"><Canvas Width="24" Height="24"><Path Data="M12,9 C13.66,9 15,10.34 15,12 C15,13.66 13.66,15 12,15 C10.34,15 9,13.66 9,12 C9,10.34 10.34,9 12,9 Z M12,3.5 L12,6 M12,18 L12,20.5 M3.5,12 L6,12 M18,12 L20.5,12 M5.8,5.8 L7.6,7.6 M16.4,16.4 L18.2,18.2 M18.2,5.8 L16.4,7.6 M7.6,16.4 L5.8,18.2" Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=ListBoxItem}}" StrokeThickness="2" StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round"/></Canvas></Viewbox>
            <TextBlock Text="{loc:Tr sectionGeneral}" Margin="12,0,0,0" VerticalAlignment="Center"/>
          </StackPanel>
        </ListBoxItem>
        <ListBoxItem>
          <StackPanel Orientation="Horizontal">
            <Viewbox Width="18" Height="18"><Canvas Width="24" Height="24"><Path Data="M3.5,7 L20.5,7 L20.5,17 L3.5,17 Z M6.5,10 L7.5,10 M10,10 L11,10 M13.5,10 L14.5,10 M17,10 L17.5,10 M7,13.5 L17,13.5" Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=ListBoxItem}}" StrokeThickness="2" StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round"/></Canvas></Viewbox>
            <TextBlock Text="{loc:Tr sectionShortcuts}" Margin="12,0,0,0" VerticalAlignment="Center"/>
          </StackPanel>
        </ListBoxItem>
        <ListBoxItem>
          <StackPanel Orientation="Horizontal">
            <Viewbox Width="18" Height="18"><Canvas Width="24" Height="24"><Path Data="M12,3.5 C16.7,3.5 20.5,7.3 20.5,12 C20.5,16.7 16.7,20.5 12,20.5 C7.3,20.5 3.5,16.7 3.5,12 C3.5,7.3 7.3,3.5 12,3.5 Z M3.5,12 L20.5,12 M12,3.5 C9.5,6 8.5,9 8.5,12 C8.5,15 9.5,18 12,20.5 C14.5,18 15.5,15 15.5,12 C15.5,9 14.5,6 12,3.5 Z" Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=ListBoxItem}}" StrokeThickness="1.6"/></Canvas></Viewbox>
            <TextBlock Text="{loc:Tr sectionLanguage}" Margin="12,0,0,0" VerticalAlignment="Center"/>
          </StackPanel>
        </ListBoxItem>
        <ListBoxItem>
          <StackPanel Orientation="Horizontal">
            <Viewbox Width="18" Height="18"><Canvas Width="24" Height="24"><Path Data="M19,9 C18,6 15.2,4 12,4 C8.5,4 5.6,6.5 5,10 M5,4 L5,10 L11,10 M5,15 C6,18 8.8,20 12,20 C15.5,20 18.4,17.5 19,14 M19,20 L19,14 L13,14" Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=ListBoxItem}}" StrokeThickness="2" StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round"/></Canvas></Viewbox>
            <TextBlock Text="{loc:Tr sectionUpdates}" Margin="12,0,0,0" VerticalAlignment="Center"/>
          </StackPanel>
        </ListBoxItem>
      </ListBox>
    </Border>

    <!-- Content (scrollable so long panes — e.g. Updates with release notes — can reach
         their action buttons) -->
    <ScrollViewer Grid.Column="1" Padding="24" VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled">
      <StackPanel x:Name="Pane"/>
    </ScrollViewer>
  </Grid>
</Window>
